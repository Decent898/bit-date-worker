APP_NAME=Slow Social Matching
APP_ENV=dev
SECRET_KEY=replace_with_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=10080

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/slow_social
REDIS_URL=redis://localhost:6379/0

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASSWORD=replace_me
SMTP_FROM=no-reply@example.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false

EMAIL_ADDR=
EMAIL_AUTH_CODE=
EMAIL_DELIVERY_MODE=smtp
EMAIL_OUTBOX_FILE=./dev_outbox.log

EDU_EMAIL_REGEX=^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.edu\\.cn$

LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=local-model
